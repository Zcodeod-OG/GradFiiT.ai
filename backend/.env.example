# ==================== Application Settings ====================
APP_NAME=AULTER.AI API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api

# ==================== Server Settings ====================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ==================== Database Settings ====================
DATABASE_URL=postgresql://username:password@localhost:5432/aulter_db
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_ECHO=false

# ==================== Redis/Cache Settings ====================
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
CACHE_PREFIX=aulter:

# ==================== AWS S3 Settings ====================
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET_NAME=aulter-storage
AWS_REGION=us-east-1
S3_UPLOAD_FOLDER=uploads
S3_RESULTS_FOLDER=results
S3_PRESIGNED_URL_EXPIRY=3600

# ==================== Authentication Settings ====================
CLERK_SECRET_KEY=your_clerk_secret_key
CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ==================== Celery Settings ====================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TRACK_STARTED=true
CELERY_TASK_TIME_LIMIT=300

# ==================== ML Model Settings ====================
ML_MODEL_PATH=./models
REPLICATE_API_TOKEN=r8_your_replicate_api_token_here
MODEL_TIMEOUT=300

# ==================== File Upload Settings ====================
MAX_UPLOAD_SIZE=10485760
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp
MIN_IMAGE_WIDTH=512
MIN_IMAGE_HEIGHT=512
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096

# ==================== CORS Settings ====================
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==================== Rate Limiting Settings ====================
RATE_LIMIT_PER_MINUTE=10
RATE_LIMIT_UPLOAD=5
RATE_LIMIT_TRYON=3

# ==================== Logging Settings ====================''
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(messa2ge)s
LOG_FILE=

# ==================== Security Settings ====================
SECRET_KEY=your-secret-key-change-in-production
ENCRYPTION_ALGORITHM=HS256
BCRYPT_ROUNDS=12

# ==================== Monitoring Settings ====================
SENTRY_DSN=
ENABLE_METRICS=true
# ==================== Replicate API ====================
REPLICATE_API_TOKEN=r8_your_replicate_api_token_here

# ==================== Try-On Provider ====================
# Active provider: fashn (default, single-call commercial VTON) or
# replicate_legacy (the old 5-stage Replicate pipeline -- kept for fallback/A-B).
TRYON_PROVIDER=fashn
TRYON_OUTPUT_RESOLUTION=1024
TRYON_OUTPUT_FORMAT=png

# ==================== Fashn.ai (default VTON provider) ====================
FASHN_API_KEY=
FASHN_BASE_URL=https://api.fashn.ai/v1
FASHN_HTTP_TIMEOUT_SECONDS=60
FASHN_POLL_INTERVAL_SECONDS=1.5
FASHN_MAX_WAIT_SECONDS=180
# Optional: when set, Fashn will POST status updates to
# {FASHN_WEBHOOK_URL}/{tryon_id}. Leave blank to fall back to polling.
FASHN_WEBHOOK_URL=
FASHN_DEFAULT_MODEL=tryon-v1.6
FASHN_BEST_MODEL=tryon-max
FASHN_BEST_NUM_SAMPLES=2
# Multi-sample on the balanced lane so the postprocessor has 2 candidates
# to score (CLIP garment fidelity + identity similarity).
FASHN_BALANCED_NUM_SAMPLES=2

# ==================== Try-On Quality Layers (L1 input gate + L2 postprocess) ====================
# Master switch. When false, Fashn outputs are returned as-is (no face restore,
# no upscale, no identity check, no smart crop). Useful for raw A/B baselines.
TRYON_POSTPROCESS_ENABLED=true
# Comma-separated lanes that get post-processing. The 'fast' lane stays raw to
# keep its latency advantage. Allowed: fast, balanced, best.
POSTPROCESS_LANES=balanced,best

# Layer 1: input quality gate (pose/blur/coverage + smart crop)
INPUT_GATE_ENABLED=true
# When false (default), the gate logs warnings only and never fails the run.
INPUT_GATE_HARD_FAIL=false
INPUT_GATE_MIN_BLUR_VAR=80.0
INPUT_GATE_MIN_BODY_COVERAGE=0.55
INPUT_GATE_SMART_CROP=true
INPUT_GATE_SMART_CROP_PADDING=0.08

# Layer 1/2: rembg-based BG isolation + composite. Off by default - extra
# latency. Turn both on together to feed Fashn a neutral background and then
# composite the VTON output back onto the user's original background.
BG_ISOLATE_ENABLED=false
BG_COMPOSE_ENABLED=false

# Layer 2: identity drift detection via CLIP face embedding. If the cosine
# similarity drops below the threshold, the runner re-runs the provider with a
# fresh seed (up to IDENTITY_RETRY_MAX times).
IDENTITY_CHECK_ENABLED=true
IDENTITY_DRIFT_THRESHOLD=0.78
IDENTITY_RETRY_MAX=1

# Layer 2: GFPGAN face restoration (Apache 2.0). Pin the version slug for
# determinism, e.g. tencentarc/gfpgan:9283608c. Leaving the bare slug uses
# Replicate's "latest" pointer.
FACE_RESTORE_ENABLED=true
FACE_RESTORE_MODEL=tencentarc/gfpgan
FACE_RESTORE_SCALE=2

# Layer 2: Real-ESRGAN upscale (BSD-3). Same versioning notes apply.
UPSCALE_ENABLED=true
UPSCALE_MODEL=nightmareai/real-esrgan
UPSCALE_FACTOR=2
# Default off because GFPGAN already restored the face; turning this on can
# over-process and create plastic skin.
UPSCALE_FACE_ENHANCE=false

POSTPROCESS_HTTP_TIMEOUT_SECONDS=60

# ==================== Stripe (Payments) ====================
# Leave blank to disable paid upgrades -- the app still runs and the
# pricing page renders "coming soon" cards instead of Subscribe buttons.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs per plan. Only Premium 2D is expected at launch;
# leave the 3D / Ultra ones blank until those features ship.
STRIPE_PRICE_PREMIUM_2D=
STRIPE_PRICE_PREMIUM_3D=
STRIPE_PRICE_ULTRA=

STRIPE_SUCCESS_URL=http://localhost:3000/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/pricing?canceled=1
STRIPE_BILLING_PORTAL_RETURN_URL=http://localhost:3000/account/billing

# ==================== Affiliate networks ====================
AFFILIATE_DISCLOSURE_TEXT=We may earn a small commission when you buy through this link, at no extra cost to you.
# Amazon Associates tracking ID per marketplace. Leave blank to skip.
AFFILIATE_AMAZON_US_TAG=
AFFILIATE_AMAZON_IN_TAG=
AFFILIATE_AMAZON_UK_TAG=
# EarnKaro / CueLinks deep-link tokens (cover 200+ Indian + global merchants).
AFFILIATE_EARNKARO_TOKEN=
AFFILIATE_CUELINKS_CID=
# Sub-ID attached to every outbound affiliate URL for attribution.
AFFILIATE_GENERIC_SUBID=gradfit